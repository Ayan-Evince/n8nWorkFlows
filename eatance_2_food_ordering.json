"jsCode": "const items = $input.all();\nconst updatedItems = items.map((item) => {\n  let status;\n  const restaurant = item?.json?.output?.restaurant;\n  const item_name = item?.json?.output?.item;\n  const add_ons = item?.json?.output?.add_ons;\n\n  if (restaurant && !item_name) {\n    status = 0;\n  } else if (!restaurant && item_name) {\n    status = 1;\n  } else if (restaurant && item_name) {\n    status = 2;\n  } else {\n    status = 3;\n  }\n\n  return {\n    status,\n    restaurant,\n    item: item_name,\n    add_ons,\n  };\n});\n\nreturn updatedItems;\n"
},
