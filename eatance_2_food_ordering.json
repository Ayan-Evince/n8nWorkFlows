"jsCode": "// Get the JSON data from previous node\nconst input = $json;\n\n// Prepare result array\nlet result = [];\n\n// Loop through each item in data\nfor (const menuItem of input.data) {\n\tif (menuItem.mandatory === 1) {\n\t\t// Clone the item but keep only the first addon\n\t\tlet clonedItem = {\n\t\t\t...menuItem,\n\t\t\taddons: menuItem.addons.length > 0 ? [menuItem.addons[0]] : []\n\t\t};\n\t\tresult.push(clonedItem);\n\t}\n}\n\n// Return as n8n output\nreturn result.map(r => ({ json: {\n  \"cust_id\": [r.id](http://r.id/), \n  \"cust_name\": [r.name](http://r.name/), \n  \"cust_mandatory\": r.mandatory, \n  \"cust_is_variation\": r.is_variation,\n  \"cust_is_variation_primary\": r.is_variation_primary,\n  \"cust_display_limit\": r.display_limit,\n  \"cust_addons\": [\n    {\n      \"id\": r.addons[0].id,\n      \"addons_name\": r.addons[0].addons_name,\n      \"addons_price\": r.addons[0].addons_price,\n      \"variation_data\": [\n        {\n          \"variation_id\":r.addons[0].variation_data[0].variation_id,\n          \"variation_price\": r.addons[0].variation_data[0].variation_price\n        }\n      ]\n    }\n  ]\n} }));\n"
},
