        "jsCode": "const data = $json;\n\nconst itemToFind = data.output.user_input_item.toLowerCase(); // normalize case\nconst menuItems = data.data.menu_items;\n\n  for (const menuItem of menuItems) {\n    if (menuItem.item_name.toLowerCase() === itemToFind) {\n      return {id: menuItem.id ?? \"\", add_ons: menuItem.check_add_ons ?? 0, item_name: menuItem.item_name ?? \"\", offer_end_date: menuItem.offer_end_date ?? \"\", offer_discount: menuItem.offer_discount ?? \"\", offer_price: menuItem.offer_price ?? \"\", offer_start_date: menuItem.offer_start_date ?? \"\", price: menuItem.price ?? \"\", restaurant_id: $input.first().json.restaurant_id ?? \"\"};\n    }\n  }\n\n  return {message: \"Item not found\"}; // not found"
